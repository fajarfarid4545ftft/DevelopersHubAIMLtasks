    "\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.linear_model import LinearRegression\n",
    "from sklearn.metrics import mean_absolute_error\n",
    "\n",
    "data = {\n",
    "    'sqft': [1100, 1500, 1800, 2200, 2700, 3000, 3500, 4000],\n",
    "    'bedrooms': [2, 3, 3, 3, 4, 4, 5, 5],\n",
    "    'price': [250000, 320000, 380000, 410000, 500000, 580000, 650000, 750000]\n",
    "}\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "X = df[['sqft', 'bedrooms']]\n",
    "y = df['price']\n",
    "\n",
    "\n",
    "house_model = LinearRegression()\n",
    "house_model.fit(X, y)\n",
    "\n",
    "\n",
    "test_house = [[2500, 3]]\n",
    "predicted_price = house_model.predict(test_house)\n",
    "\n",
    "print(f\"Predicted Price for a 2500sqft house: ${predicted_price[0]:,.2f}\")\n",
    "\n",
    "plt.scatter(df['sqft'], df['price'], color='blue', label='Data Points')\n",
    "plt.plot(df['sqft'], house_model.predict(X), color='red', label='Trend Line')\n",
    "plt.xlabel('Square Footage')\n",
    "plt.ylabel('Price')\n",
    "plt.title('House Size vs. Price Trend')\n",
    "plt.legend()\n",
    "plt.show()"
   ]
  }
